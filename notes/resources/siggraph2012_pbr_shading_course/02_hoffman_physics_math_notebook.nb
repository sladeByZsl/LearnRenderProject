       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "0", ",", 
         RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", "pCol"}]}], "]"}], ",", 
