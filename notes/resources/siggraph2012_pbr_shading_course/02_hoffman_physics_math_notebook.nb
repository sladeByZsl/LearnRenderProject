          RowBox[{
           RowBox[{"\[Alpha]abc1", "\[Rule]", "#"}], ",", 
           RowBox[{"\[Alpha]abc2", "\[Rule]", "x"}]}], "}"}]}], "&"}], "/@", 
       RowBox[{"{", 
        RowBox[{"1", ",", "10", ",", "100", ",", "1000"}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "0", ",", 
        RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", "abcCol"}]}], "]"}], ",", 
    RowBox[{"\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(abc2\)]\) = \>\"", "<>", 
     RowBox[{"ToString", "[", "x", "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
