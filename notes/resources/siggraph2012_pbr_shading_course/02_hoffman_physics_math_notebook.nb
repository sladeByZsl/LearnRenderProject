Cell[CellGroupData[{

Cell["Phong NDF", "Section",
 CellChangeTimes->{{3.552695863749794*^9, 3.552695865395516*^9}}],

Cell["This is the unnormalized Phong distribution function:", "Text",
 CellChangeTimes->{{3.552696372282118*^9, 3.5526963893721333`*^9}, {
  3.55269659742524*^9, 3.5526965980151653`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"unnormalizedphong", "=", 
   SuperscriptBox[
    RowBox[{"Cos", "[", "\[Theta]", "]"}], "\[Alpha]p"]}], ";"}]], "Input",
 CellChangeTimes->{{3.552696601702882*^9, 3.5526966084060287`*^9}, 
   3.5550438913301163`*^9}],

Cell["\<\
Compute the normalization factor (relative to projected area) for the Phong \
distribution function:\
\>", "Text",
 CellChangeTimes->{{3.552696632027666*^9, 3.552696638622739*^9}, {
  3.552786004879315*^9, 3.5527860053268347`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"phongnormf", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"unnormalizedphong", " ", 
     RowBox[{"Sin", "[", "\[Theta]", "]"}], 
     RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Phi]", ",", 
      RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", "0", ",", 
      RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]p", ">", "0"}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.552696681822274*^9, 3.55269671632026*^9}, {
   3.5550350779768763`*^9, 3.555035088028407*^9}, {3.5550361293658543`*^9, 
   3.555036171891255*^9}, {3.555041850881073*^9, 3.555041864795227*^9}, 
   3.555041977370434*^9, 3.555043769215082*^9}],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", "\[Pi]"}], 
  RowBox[{"2", "+", "\[Alpha]p"}]]], "Output",
 CellChangeTimes->{3.5551105154129267`*^9, 3.55519687439207*^9, 
  3.556115229734169*^9, 3.556220442726688*^9, 3.556220968726087*^9, 
  3.55622511056651*^9, 3.556225190925539*^9, 3.556232070400463*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"phong", "=", 
  FractionBox["unnormalizedphong", "phongnormf"]}]], "Input",
 CellChangeTimes->{{3.55269679382972*^9, 3.5526968318266163`*^9}}],

Cell[BoxData[
 FractionBox[
  RowBox[{
   RowBox[{"(", 
    RowBox[{"2", "+", "\[Alpha]p"}], ")"}], " ", 
   SuperscriptBox[
    RowBox[{"Cos", "[", "\[Theta]", "]"}], "\[Alpha]p"]}], 
  RowBox[{"2", " ", "\[Pi]"}]]], "Output",
 CellChangeTimes->{3.555110515446748*^9, 3.555196874421967*^9, 
  3.556115229777197*^9, 3.556220442758518*^9, 3.5562209687481422`*^9, 
  3.556225110597643*^9, 3.5562251909626083`*^9, 3.556232070421815*^9}]
}, Open  ]],

Cell["\<\
Here are the distribution curves for some logarithmically spaced cosine \
powers (as well as 0, which corresponds to the uniform distribution):\
\>", "Text",
 CellChangeTimes->{{3.5561607958143187`*^9, 3.556160851006217*^9}}],

Cell[CellGroupData[{

