Cell[TextData[{
 "The imaginary part is 0 \[Dash] looks like the normalization factor \
actually is real-valued and ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " is just being weird. If we were actually going to use this, we would fit a \
cheap function to the curve instead of using the analytical expression. But \
since we are just comparing it to other NDFs, no need to do that.  Let\
\[CloseCurlyQuote]s compare it to Blinn-Phong, using the Beckmann parameter \
conversion (according to the Cook-Torrance paper, the Beckmann and \
Torrance-Sparrow parameterizations are the same \[Dash] both are equal to RMS \
slope):"
}], "Text",
 CellChangeTimes->{{3.552643718482052*^9, 3.552643829232415*^9}, {
   3.552643866255288*^9, 3.552643872405365*^9}, 3.5526449157465982`*^9, {
   3.552782186479651*^9, 3.5527822603002462`*^9}, {3.552784006580268*^9, 
   3.55278403348545*^9}, {3.5527840652173777`*^9, 3.55278410256004*^9}, {
   3.552784279094982*^9, 3.5527842924967127`*^9}, {3.555037482183391*^9, 
   3.555037482676506*^9}, {3.5550395364381523`*^9, 3.5550395379909153`*^9}, {
   3.555092499077568*^9, 3.5550925333331223`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"torrancesparrow", "=", 
  FractionBox["unnormalizedtorrancesparrow", 
   RowBox[{"Re", "[", "normts", "]"}]], " "}]], "Input",
 CellChangeTimes->{{3.552643907438633*^9, 3.552643911149118*^9}, {
  3.555038377217135*^9, 3.555038378399341*^9}}],

Cell[BoxData[
 FractionBox[
  RowBox[{"4", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[Theta]", "2"], 
      SuperscriptBox["\[Alpha]ts", "2"]]}]]}], 
  RowBox[{
   SuperscriptBox["\[Pi]", 
    RowBox[{"3", "/", "2"}]], " ", 
   RowBox[{"Re", "[", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       SuperscriptBox["\[Alpha]ts", "2"]}]], " ", "\[Alpha]ts", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], " ", 
        RowBox[{"Erf", "[", 
         RowBox[{
          FractionBox["\[Pi]", 
           RowBox[{"2", " ", "\[Alpha]ts"}]], "-", 
          RowBox[{"\[ImaginaryI]", " ", "\[Alpha]ts"}]}], "]"}]}], "+", 
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"Erf", "[", 
         RowBox[{
          FractionBox["\[Pi]", 
           RowBox[{"2", " ", "\[Alpha]ts"}]], "+", 
          RowBox[{"\[ImaginaryI]", " ", "\[Alpha]ts"}]}], "]"}]}], "+", 
       RowBox[{"2", " ", 
        RowBox[{"Erfi", "[", "\[Alpha]ts", "]"}]}]}], ")"}]}], 
    "]"}]}]]], "Output",
 CellChangeTimes->{3.55511052503782*^9, 3.555196885562911*^9, 
  3.556115244241419*^9, 3.5562204559595337`*^9, 3.556220981316299*^9, 
  3.556225122968196*^9, 3.556225202061874*^9, 3.5562320830104637`*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"torrancesparrow", "/.", 
        RowBox[{"\[Alpha]ts", "\[Rule]", "#"}]}], "&"}], "/@", 
      RowBox[{"Range", "[", 
       RowBox[{"0.2", ",", "0.5", ",", "0.1"}], "]"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"phong", "/.", 
        RowBox[{"\[Alpha]p", "\[Rule]", 
         RowBox[{"\[Alpha]b2\[Alpha]p", "[", "#", "]"}]}]}], "&"}], "/@", 
