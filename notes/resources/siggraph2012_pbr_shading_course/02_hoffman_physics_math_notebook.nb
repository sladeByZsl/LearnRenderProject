          RowBox[{
           RowBox[{"\[Alpha]sgd1", "\[Rule]", "x"}], ",", 
           RowBox[{"\[Alpha]sgd2", "\[Rule]", "#"}]}], "}"}]}], "&"}], "/@", 
       RowBox[{"{", 
        RowBox[{"0.0", ",", "0.5", ",", "1.0", ",", "1.5"}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "0", ",", 
        RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", "sgdCol"}]}], "]"}], ",", 
    RowBox[{"\"\<\[Alpha]sgd1 = \>\"", "<>", 
     RowBox[{"ToString", "[", "x", "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"GraphicsGrid", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"plot1", "/@", 
      RowBox[{"{", 
       RowBox[{"0.0", ",", "0.5", ",", "1.0", ",", "1.5"}], "}"}]}], ",", 
     RowBox[{"plot2", "/@", 
