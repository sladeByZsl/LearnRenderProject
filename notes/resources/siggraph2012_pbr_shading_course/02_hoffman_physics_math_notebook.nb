Cell[CellGroupData[{

Cell["Torrance-Sparrow NDF", "Section"],

Cell["\<\
This NDF is a Gaussian on the angle between the microfacet normal and the \
macroscopic surface normal. We will need to normalize it since Torrance and \
Sparrow did not supply a normalization factor:\
\>", "Text",
 CellChangeTimes->{{3.5526447833905563`*^9, 3.552644812508931*^9}, {
  3.55278197623765*^9, 3.552781977922722*^9}, {3.555092410122161*^9, 
  3.555092410607409*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"unnormalizedtorrancesparrow", "=", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox["\[Theta]", 
        RowBox[{"\[Alpha]ts", " "}]], ")"}], "2"]}]]}], ";"}]], "Input",
 CellChangeTimes->{{3.552644839911233*^9, 3.552644849550996*^9}, {
  3.552782003747527*^9, 3.552782033162341*^9}, {3.552784197568267*^9, 
  3.552784232790269*^9}, {3.555037402953141*^9, 3.55503741184731*^9}, {
  3.555043946843354*^9, 3.555043949616948*^9}}],

Cell["We'll try for an analytical normalization factor:", "Text",
 CellChangeTimes->{3.555092416794115*^9}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"normts", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"unnormalizedtorrancesparrow", " ", 
     RowBox[{"Sin", "[", "\[Theta]", "]"}], 
     RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Phi]", ",", 
      RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", "0", ",", 
      RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]ts", ">", "0"}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.5525990263970346`*^9, 3.552599045082119*^9}, 
   3.55278204540058*^9, {3.555037415334976*^9, 3.5550374519272614`*^9}, {
   3.555041284879466*^9, 3.555041295531678*^9}, 3.55504197748781*^9, 
   3.555043769630857*^9}],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "4"], " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"-", 
    SuperscriptBox["\[Alpha]ts", "2"]}]], " ", 
  SuperscriptBox["\[Pi]", 
   RowBox[{"3", "/", "2"}]], " ", "\[Alpha]ts", " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     RowBox[{"Erf", "[", 
      RowBox[{
       FractionBox["\[Pi]", 
        RowBox[{"2", " ", "\[Alpha]ts"}]], "-", 
       RowBox[{"\[ImaginaryI]", " ", "\[Alpha]ts"}]}], "]"}]}], "+", 
    RowBox[{"\[ImaginaryI]", " ", 
     RowBox[{"Erf", "[", 
      RowBox[{
       FractionBox["\[Pi]", 
        RowBox[{"2", " ", "\[Alpha]ts"}]], "+", 
       RowBox[{"\[ImaginaryI]", " ", "\[Alpha]ts"}]}], "]"}]}], "+", 
    RowBox[{"2", " ", 
     RowBox[{"Erfi", "[", "\[Alpha]ts", "]"}]}]}], ")"}]}]], "Output",
 CellChangeTimes->{3.555110524774938*^9, 3.5551968853347178`*^9, 
  3.556115243645797*^9, 3.5562204558921347`*^9, 3.556220981181818*^9, 
  3.556225122851577*^9, 3.556225201851234*^9, 3.55623208284908*^9}]
}, Open  ]],

Cell["\<\
Wow, that\[CloseCurlyQuote]s ugly! It also appears to be complex-valued, \
which is odd since the function being integrated was real-valued. Let\
\[CloseCurlyQuote]s see if it is really complex-valued:\
\>", "Text",
 CellChangeTimes->{{3.5525987819624662`*^9, 3.552598852686949*^9}, {
  3.552599437415131*^9, 3.552599470149036*^9}, {3.552643575695447*^9, 
  3.552643599066255*^9}, {3.552643659279387*^9, 3.5526437097786016`*^9}, {
  3.555037500235601*^9, 3.5550375013469963`*^9}, {3.555092434724143*^9, 
  3.555092435042831*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Im", "[", "normts", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]ts", ",", "0.05", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "0.01"}], ",", "0.01"}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Thick"}]}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.552643641483067*^9, 3.552643645697507*^9}, {
   3.5526438881902723`*^9, 3.552643888465114*^9}, 3.552644896070663*^9, {
