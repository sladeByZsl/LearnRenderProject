Cell[CellGroupData[{

Cell["Beckmann NDF", "Section"],

Cell["\<\
This is the unnormalized Beckmann distribution function:\
\>", "Text",
 CellChangeTimes->{{3.552696372282118*^9, 3.5526963893721333`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"unnormalizedbeckmann", "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SuperscriptBox["\[Alpha]b", "2"], 
       SuperscriptBox[
        RowBox[{"Cos", "[", "\[Theta]", "]"}], "4"]}]], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       RowBox[{"(", 
        FractionBox[
         RowBox[{"1", "-", 
          SuperscriptBox[
           RowBox[{"Cos", "[", "\[Theta]", "]"}], "2"]}], 
         RowBox[{
          SuperscriptBox[
           RowBox[{"Cos", "[", "\[Theta]", "]"}], "2"], 
          SuperscriptBox["\[Alpha]b", "2"]}]], ")"}]}]]}]}], ";"}], 
  "    "}]], "Input",
 CellChangeTimes->{{3.552576003244931*^9, 3.5525760522928457`*^9}, {
  3.5525806631035852`*^9, 3.552580672913624*^9}, {3.552781190123333*^9, 
  3.552781219824184*^9}, {3.555036541935034*^9, 3.555036542767063*^9}, {
  3.555043909835258*^9, 3.555043911702612*^9}}],

Cell["\<\
Compute the normalization factor (relative to projected area) for the \
Beckmann distribution function:\
\>", "Text",
 CellChangeTimes->{{3.552575938590231*^9, 3.55257594025502*^9}, {
  3.552576178164091*^9, 3.5525761794206057`*^9}, {3.552695875847143*^9, 
  3.5526959301673203`*^9}, {3.552785993174561*^9, 3.5527860000082407`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"beckmannnormf", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"unnormalizedbeckmann", " ", 
     RowBox[{"Sin", "[", "\[Theta]", "]"}], 
     RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Phi]", ",", 
      RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", "0", ",", 
      RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]b", ">", "0"}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.552655550567747*^9, 3.552655573193005*^9}, {
   3.5527811151689577`*^9, 3.55278111941728*^9}, {3.555036232170621*^9, 
   3.555036264040091*^9}, {3.555041279789892*^9, 3.555041282395924*^9}, {
   3.555041891548169*^9, 3.555041892426409*^9}, 3.555041977468412*^9, 
   3.555043769283873*^9, 3.555083723814262*^9}],

Cell[BoxData["\[Pi]"], "Output",
 CellChangeTimes->{3.5551105166254387`*^9, 3.5551968758518867`*^9, 
  3.556115233098366*^9, 3.556220446299417*^9, 3.556220972151856*^9, 
  3.556225113857347*^9, 3.556225192316787*^9, 3.5562320736644983`*^9}]
}, Open  ]],

Cell[TextData[{
 "We see here that the correct normalization factor for the Beckmann \
distribution, given normalization over projected area, is ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", "\[Pi]"], TraditionalForm]]],
 "."
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"beckmann", "=", 
  FractionBox[
   RowBox[{"unnormalizedbeckmann", " "}], "beckmannnormf"]}]], "Input",
 CellChangeTimes->{{3.5527811495968246`*^9, 3.552781159038968*^9}, {
  3.555036534318121*^9, 3.555036535197619*^9}}],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox[
          RowBox[{"Cos", "[", "\[Theta]", "]"}], "2"]}], ")"}], " ", 
       SuperscriptBox[
        RowBox[{"Sec", "[", "\[Theta]", "]"}], "2"]}], 
      SuperscriptBox["\[Alpha]b", "2"]]}]], " ", 
   SuperscriptBox[
    RowBox[{"Sec", "[", "\[Theta]", "]"}], "4"]}], 
  RowBox[{"\[Pi]", " ", 
   SuperscriptBox["\[Alpha]b", "2"]}]]], "Output",
 CellChangeTimes->{3.555110516649037*^9, 3.555196875876967*^9, 
  3.5561152331268873`*^9, 3.5562204463275223`*^9, 3.556220972186401*^9, 
  3.556225113892449*^9, 3.556225192350934*^9, 3.55623207368804*^9}]
}, Open  ]],

Cell[TextData[{
 "The Beckmann ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Alpha]", "b"], " "}], TraditionalForm]]],
 "parameter is equal to the RMS (root mean square) microfacet slope. \
Therefore its valid range is from 0 (non-inclusive \[Dash] 0 corresponds to a \
perfect mirror or Dirac delta and causes divide by 0 errors in the Beckmann \
formulation) and up to arbitrarily high values. There is no special \
significance to a value of 1 \[Dash] this just means that the RMS slope is \
1/1 or 45\[Degree]. We will look at the shape of the Beckmann NDF for \
moderately rough surfaces (",
 Cell[BoxData[
  FormBox["m", TraditionalForm]]],
 " from 0.4 to 1):"
}], "Text",
 CellChangeTimes->{{3.5525763796794357`*^9, 3.552576379679497*^9}, {
  3.552576557407625*^9, 3.552576566222907*^9}, {3.555037144126562*^9, 
  3.555037149341669*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"beckmann", "/.", 
      RowBox[{"\[Alpha]b", "\[Rule]", "#"}]}], "&"}], "/@", 
    RowBox[{"Range", "[", 
     RowBox[{"0.4", ",", "1.0", ",", "0.1"}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", "0", ",", 
     RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", " ", "bCol"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.5525802133552732`*^9, 3.552580237358618*^9}, {
   3.552580419585608*^9, 3.552580422192079*^9}, {3.552580933397088*^9, 
