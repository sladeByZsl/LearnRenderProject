 GraphicsBox[{{}, {}, 
   {Hue[0.67, 0.6, 0.6], Thickness[Large], LineBox[CompressedData["
1:eJxNz38sFAAUB/AjYWJljDJd1Goux4ZLLhdXqnHtNsxFZq5Z18oaV/RHdxwt
