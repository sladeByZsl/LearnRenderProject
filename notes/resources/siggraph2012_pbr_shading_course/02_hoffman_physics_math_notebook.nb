Cell[TextData[{
 "This behavior is unfortunate for environment map prefiltering, since the \
frequency content of the NDF decreases to a certain roughness and then starts \
increasing with ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]]],
 ", Beckmann is supposed to be a good match to real-world measurements, but I \
am not sure over what range of parameters these comparisons were carried out. \
Are values this high (or even higher than 0.75, where the local minima starts \
appearing) observed in practice?"
}], "Text"],

Cell[TextData[{
 "Let us compare the Beckmann and Phong NDF, using an equivalence between the \
parameters of the two NDFs published in \"Microfacet Models for Refraction \
through Rough Surfaces\" (EGSR 2007) - ",
 "note that the equivalence breaks down for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Alpha]", "b"], ">", "1"}], TraditionalForm]]],
 ":"
}], "Text",
 CellChangeTimes->{
  3.552581023904249*^9, {3.555044521864203*^9, 3.55504453449397*^9}, 
   3.555092321228294*^9, {3.556161111097734*^9, 3.5561611275502157`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Alpha]b2\[Alpha]p", "[", "\[Alpha]b_", "]"}], ":=", "  ", 
  RowBox[{
   FractionBox["2", 
    SuperscriptBox["\[Alpha]b", "2"]], "-", "2"}]}]], "Input",
 CellChangeTimes->{{3.552581041211561*^9, 3.552581048871852*^9}, {
  3.552781399275114*^9, 3.552781450283422*^9}, {3.552781524764889*^9, 
  3.552781530017214*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GraphicsRow", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"beckmann", "/.", 
            RowBox[{"\[Alpha]b", "\[Rule]", "#"}]}], "&"}], "/@", 
          RowBox[{"Range", "[", 
           RowBox[{"0.2", ",", "0.5", ",", "0.1"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"phong", "/.", 
            RowBox[{"\[Alpha]p", "\[Rule]", 
             RowBox[{"\[Alpha]b2\[Alpha]p", "[", "#", "]"}]}]}], "&"}], "/@", 
          RowBox[{"Range", "[", 
           RowBox[{"0.2", ",", "0.5", ",", "0.1"}], "]"}]}]}], "}"}], ",", 
       "    ", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "0", ",", 
         RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"bCol", ",", "pCol"}], "}"}]}]}], "]"}], ",", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"beckmann", "/.", 
            RowBox[{"\[Alpha]b", "\[Rule]", "#"}]}], "&"}], "/@", 
          RowBox[{"Range", "[", 
           RowBox[{"0.6", ",", "1.0", ",", "0.1"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"phong", "/.", 
            RowBox[{"\[Alpha]p", "\[Rule]", 
             RowBox[{"\[Alpha]b2\[Alpha]p", "[", "#", "]"}]}]}], "&"}], "/@", 
          RowBox[{"Range", "[", 
           RowBox[{"0.6", ",", "1.0", ",", "0.1"}], "]"}]}]}], "}"}], ",", 
       "    ", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "0", ",", 
         RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"bCol", ",", "pCol"}], "}"}]}]}], "]"}]}], "}"}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "Full"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.556161009489976*^9, 3.556161063305976*^9}, {
  3.556224847797057*^9, 3.556224883596415*^9}}],

