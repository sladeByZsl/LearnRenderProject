Cell["\<\
We see that with an \[Alpha]abc2 value of 0.5, ABC is significantly \
\[OpenCurlyDoubleQuote]spikier\[CloseCurlyDoubleQuote] than Trowbridge-Reitz \
when modeling rough surfaces (on the left), and extremely so when modeling \
smooth ones (on the right).\
\>", "Text",
 CellChangeTimes->{{3.554526584246538*^9, 3.554526636568674*^9}, {
  3.555093095082222*^9, 3.5550931242628927`*^9}, {3.55616269539038*^9, 
  3.556162705234058*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell["Shifted Gamma Distribution", "Section",
 CellChangeTimes->{{3.552966912026547*^9, 3.552966916764233*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"p22", "[", "x_", "]"}], ":=", 
  RowBox[{
   FractionBox[
    SuperscriptBox["\[Alpha]sgd1", 
     RowBox[{"\[Alpha]sgd2", "-", "1"}]], 
    RowBox[{"Gamma", "[", 
     RowBox[{
      RowBox[{"1", "-", "\[Alpha]sgd2"}], ",", "\[Alpha]sgd1"}], "]"}]], 
   FractionBox[
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", 
      FractionBox[
       RowBox[{
        SuperscriptBox["\[Alpha]sgd1", "2"], "+", "x"}], "\[Alpha]sgd1"]}]], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["\[Alpha]sgd1", "2"], "+", "x"}], ")"}], 
     "\[Alpha]sgd2"]]}]}]], "Input",
 CellChangeTimes->{{3.5529671343128138`*^9, 3.55296722466805*^9}, {
  3.552967503553508*^9, 3.5529675251425*^9}, {3.552967596892173*^9, 
  3.552967755117861*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sgd", "=", 
  FractionBox[
   RowBox[{"p22", "[", 
    FractionBox[
     RowBox[{"1", "-", 
      SuperscriptBox[
       RowBox[{"Cos", "[", "\[Theta]", "]"}], "2"]}], 
     SuperscriptBox[
      RowBox[{"Cos", "[", "\[Theta]", "]"}], "2"]], "]"}], 
   RowBox[{"\[Pi]", " ", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "\[Theta]", "]"}], "4"]}]]}]], "Input",
 CellChangeTimes->{{3.5529682775240917`*^9, 3.5529682864670677`*^9}, {
   3.5529683255163116`*^9, 3.552968372485461*^9}, 3.552970328565012*^9}],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       SuperscriptBox["\[Alpha]sgd1", "2"], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox[
           RowBox[{"Cos", "[", "\[Theta]", "]"}], "2"]}], ")"}], " ", 
        SuperscriptBox[
         RowBox[{"Sec", "[", "\[Theta]", "]"}], "2"]}]}], "\[Alpha]sgd1"]}]], 
   " ", 
   SuperscriptBox["\[Alpha]sgd1", 
    RowBox[{
     RowBox[{"-", "1"}], "+", "\[Alpha]sgd2"}]], " ", 
   SuperscriptBox[
    RowBox[{"Sec", "[", "\[Theta]", "]"}], "4"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["\[Alpha]sgd1", "2"], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox[
          RowBox[{"Cos", "[", "\[Theta]", "]"}], "2"]}], ")"}], " ", 
       SuperscriptBox[
        RowBox[{"Sec", "[", "\[Theta]", "]"}], "2"]}]}], ")"}], 
    RowBox[{"-", "\[Alpha]sgd2"}]]}], 
  RowBox[{"\[Pi]", " ", 
   RowBox[{"Gamma", "[", 
    RowBox[{
     RowBox[{"1", "-", "\[Alpha]sgd2"}], ",", "\[Alpha]sgd1"}], 
    "]"}]}]]], "Output",
 CellChangeTimes->{3.555110542526657*^9, 3.555196905034925*^9, 
  3.556115269393594*^9, 3.5562204777790194`*^9, 3.5562210057034082`*^9, 
  3.556225144671217*^9, 3.556225220851222*^9, 3.556232105341992*^9}]
}, Open  ]],

Cell["\<\
First, let\[CloseCurlyQuote]s confirm that it\[CloseCurlyQuote]s normalized, \
using an analytical integral:\
\>", "Text",
 CellChangeTimes->{{3.552968463299892*^9, 3.552968477171542*^9}, {
  3.552970388179008*^9, 3.552970389221559*^9}, {3.555044921529364*^9, 
  3.555044922176208*^9}, {3.5550932021196327`*^9, 3.555093216584258*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sgdnormf", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"sgd", " ", 
     RowBox[{"Sin", "[", "\[Theta]", "]"}], 
     RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Phi]", ",", 
      RowBox[{"-", "\[Pi]"}], ",", " ", "\[Pi]"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", "0", ",", 
      RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Alpha]sgd1", ">", "0"}], ",", 
       RowBox[{"\[Alpha]sgd2", ">", "0"}]}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.552968410791183*^9, 3.5529684301812897`*^9}, {
   3.555041302092784*^9, 3.555041310555086*^9}, 3.555043750996263*^9, {
   3.555044929077643*^9, 3.555044941490073*^9}}],

Cell[BoxData["1"], "Output",
 CellChangeTimes->{3.555110564987361*^9, 3.555196928289957*^9, 
  3.5561152933798847`*^9, 3.5562205018178587`*^9, 3.556221029370327*^9, 
  3.5562251694026403`*^9, 3.55622524366696*^9, 3.556232129432055*^9}]
}, Open  ]],

Cell["\<\
Yes, it\[CloseCurlyQuote]s normalized. Let\[CloseCurlyQuote]s take a look at \
various parameter values, spanning the rough-to-moderate part of the range of \
values used for fitting SGD to the Matusik database:\
\>", "Text",
 CellChangeTimes->{{3.552970403431898*^9, 3.552970408693489*^9}, {
   3.552972303639613*^9, 3.552972317964855*^9}, {3.552972459802701*^9, 
