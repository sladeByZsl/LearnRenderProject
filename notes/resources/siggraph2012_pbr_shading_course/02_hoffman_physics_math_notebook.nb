Cell[TextData[{
 "We see here that at ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Alpha]", "b"], TraditionalForm]]],
 "values above 0.75, a local minimum starts appearing at 0\[Degree]. This is \
significantly different than a Phong or Gaussian lobe, where the \"roughest\" \
possible surface is a uniform distribution. The Beckmann distribution is \
qualitatively different in that its parameter is not related to the variance \
of the angle but the mean of the slope. Thus a \"very rough\" surface in the \
Beckmann context is not a uniform or almost-uniform distribution, but a \
distribution clustered around high slopes. Let us look at even larger values \
of ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]]],
 ":"
}], "Text",
 CellChangeTimes->{{3.5525802605302362`*^9, 3.552580267714323*^9}, {
   3.552580963775898*^9, 3.552580964597946*^9}, {3.552792755075995*^9, 
   3.552792772703225*^9}, 3.555037075584127*^9}],

