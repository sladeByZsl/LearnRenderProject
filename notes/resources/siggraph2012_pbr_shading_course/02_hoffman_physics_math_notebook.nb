           RowBox[{"-", "2"}], "+", "\[Alpha]abc2"}], ")"}]}]}], ")"}]}]}], 
    ")"}]}], 
  RowBox[{
   SuperscriptBox["\[Alpha]abc1", "2"], " ", 
