Cell["\<\
All in all, the behavior appears to be very similar to Phong. The curves for \
rough surfaces are a bit higher at glancing angles, but the overall trend is \
towards a uniform distribution, like Phong (and unlike Beckmann). Given this \
similarity in behavior and the much higher computational complexity of the \
Torrance-Sparrow NDF (even higher than it appears as first, since it uses the \
angle directly rather than the cosine), there does not appear to be a reason \
to use it.\
\>", "Text",
 CellChangeTimes->{{3.552646995336215*^9, 3.552647112033833*^9}, {
   3.552785013944096*^9, 3.552785026207662*^9}, {3.552786850360931*^9, 
   3.552786864354357*^9}, 3.555092611526641*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell["Trowbridge-Reitz NDF", "Section",
 CellChangeTimes->{{3.552654703817362*^9, 3.5526547114119787`*^9}, {
  3.552654928561977*^9, 3.552654929537348*^9}}],

Cell["\<\
The original paper by Trowbridge and Reitz, the 1977 Blinn paper, and the \
2007 paper by Walter et al. (where they refer to it as \
\[OpenCurlyDoubleQuote]the GGX distribution\[CloseCurlyDoubleQuote]) all have \
slightly different forms of this NDF. They are all equivalent other than \
constant factors; we will independently derive the normalization factor here:\
\>", "Text",
 CellChangeTimes->{{3.552654733399074*^9, 3.5526548589210253`*^9}, {
  3.552654899220071*^9, 3.552654909088257*^9}, {3.552655114758593*^9, 
  3.552655166324361*^9}, {3.552785928618514*^9, 3.5527859560821533`*^9}, {
  3.5550453593075314`*^9, 3.555045361393745*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"unnormalizedtrowbridgereitz", "=", 
   FractionBox[
    SuperscriptBox["\[Alpha]tr", "2"], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"Cos", "[", "\[Theta]", "]"}], "2"], 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["\[Alpha]tr", "2"], "-", "1"}], ")"}]}], "+", "1"}], 
      ")"}], "2"]]}], ";"}]], "Input",
 CellChangeTimes->{{3.552654934359524*^9, 3.5526549441006203`*^9}, {
   3.552654997229697*^9, 3.5526550092537727`*^9}, {3.5526550400719233`*^9, 
   3.55265506619907*^9}, 3.552655104926083*^9, {3.5526551881697903`*^9, 
   3.5526551883219137`*^9}, {3.552655225795411*^9, 3.55265526512685*^9}, {
   3.552655300521131*^9, 3.552655300847109*^9}, {3.552657901898336*^9, 
   3.5526579056864634`*^9}, {3.552785960890239*^9, 3.552785966544196*^9}, {
   3.5550409393282623`*^9, 3.555040940204691*^9}, {3.555041245220435*^9, 
   3.555041245979415*^9}, {3.555043969665841*^9, 3.555043971967902*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"trowbridgereitznormf", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"unnormalizedtrowbridgereitz", " ", 
     RowBox[{"Sin", "[", "\[Theta]", "]"}], 
     RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Phi]", ",", 
      RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", "0", ",", 
      RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]tr", ">", "0"}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.552655381038802*^9, 3.5526553909946527`*^9}, {
   3.5526554313539762`*^9, 3.552655479576037*^9}, {3.552657912893998*^9, 
   3.552657913284905*^9}, {3.552786034471776*^9, 3.5527860492818623`*^9}, {
   3.5550409453739767`*^9, 3.555040966908627*^9}, {3.555041255268704*^9, 
   3.555041259388774*^9}, 3.5550437701389313`*^9}],

Cell[BoxData["\[Pi]"], "Output",
 CellChangeTimes->{3.5551105336209717`*^9, 3.5551968954285917`*^9, 
  3.5561152550317307`*^9, 3.5562204667638073`*^9, 3.556220991413761*^9, 
  3.556225132896627*^9, 3.5562252117023897`*^9, 3.5562320933803797`*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"trowbridgereitz", "=", 
  FractionBox[
   RowBox[{"unnormalizedtrowbridgereitz", " "}], 
   "trowbridgereitznormf"]}]], "Input",
 CellChangeTimes->{{3.552786087869986*^9, 3.5527860980171537`*^9}, {
  3.5550409748276253`*^9, 3.555040976155188*^9}}],

Cell[BoxData[
 FractionBox[
  SuperscriptBox["\[Alpha]tr", "2"], 
  RowBox[{"\[Pi]", " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         SuperscriptBox["\[Alpha]tr", "2"]}], ")"}], " ", 
       SuperscriptBox[
        RowBox[{"Cos", "[", "\[Theta]", "]"}], "2"]}]}], ")"}], 
    "2"]}]]], "Output",
 CellChangeTimes->{3.555110533680311*^9, 3.5551968955000477`*^9, 
  3.55611525514087*^9, 3.556220466794541*^9, 3.556220991506741*^9, 
  3.5562251330891657`*^9, 3.5562252117584257`*^9, 3.556232093474029*^9}]
}, Open  ]],

Cell["\<\
We\[CloseCurlyQuote]ll look at the distribution curves for moderate parameter \
values (on the left) as well as for high parameter values (on the right):\
\>", "Text",
 CellChangeTimes->{{3.552789428280205*^9, 3.552789458026684*^9}, {
  3.552791584255123*^9, 3.552791598454843*^9}, {3.555092656207025*^9, 
  3.555092656659875*^9}, {3.556161520279943*^9, 3.556161534551874*^9}, {
  3.556161598010078*^9, 3.556161628439026*^9}}],

