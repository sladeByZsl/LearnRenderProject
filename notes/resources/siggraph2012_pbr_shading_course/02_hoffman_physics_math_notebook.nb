  RowBox[{"Labeled", "[", 
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"sgd", "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"\[Alpha]sgd1", "\[Rule]", "#"}], ",", 
           RowBox[{"\[Alpha]sgd2", "\[Rule]", "x"}]}], "}"}]}], "&"}], "/@", 
       RowBox[{"{", 
        RowBox[{"1.0", ",", "0.5", ",", "0.2", ",", "0.1"}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "0", ",", 
        RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", "sgdCol"}]}], "]"}], ",", 
    RowBox[{"\"\<\[Alpha]sgd2 = \>\"", "<>", 
     RowBox[{"ToString", "[", "x", "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"plot2", "[", "x_", "]"}], ":=", 
  RowBox[{"Labeled", "[", 
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
