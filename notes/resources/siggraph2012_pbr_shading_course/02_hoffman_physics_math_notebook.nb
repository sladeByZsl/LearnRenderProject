Cell["And an interactive graph:", "Text",
 CellChangeTimes->{{3.552697970778247*^9, 3.55269801508466*^9}, {
  3.5526984234700613`*^9, 3.552698428066593*^9}, {3.5527808114314957`*^9, 
  3.552780827519628*^9}, {3.553341766840415*^9, 3.553341771692103*^9}, {
  3.556160880222948*^9, 3.556160883635144*^9}, {3.556160927406295*^9, 
  3.556160928130972*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"phong", "/.", 
