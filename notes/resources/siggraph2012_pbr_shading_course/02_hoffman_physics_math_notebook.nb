Cell["ABC NDF", "Section",
 CellChangeTimes->{{3.552866874383231*^9, 3.552866875380569*^9}, {
  3.5528776419685907`*^9, 3.552877643238391*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"unnormalizedabc", "=", 
   FractionBox["1", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"\[Alpha]abc1", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ")"}]}]}], ")"}], 
     "\[Alpha]abc2"]]}], ";"}]], "Input",
 CellChangeTimes->{{3.552867274660677*^9, 3.552867362427144*^9}, {
   3.552867394062806*^9, 3.552867428037122*^9}, 3.5550439918582497`*^9}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"abcnormf", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"unnormalizedabc", " ", 
     RowBox[{"Sin", "[", "\[Theta]", "]"}], 
     RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Phi]", ",", 
      RowBox[{"-", "\[Pi]"}], ",", "\[Pi]"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", "0", ",", 
      RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Alpha]abc1", ">", "0"}], ",", 
       RowBox[{"\[Alpha]abc2", ">", "0"}]}], "}"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.5528675115002813`*^9, 3.552867538724318*^9}, {
   3.552877343112473*^9, 3.552877349410721*^9}, {3.5550412676552362`*^9, 
   3.555041270548715*^9}, {3.5550420387653103`*^9, 3.5550420580023403`*^9}, 
   3.55504377048309*^9}],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", "\[Pi]", " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "+", "\[Alpha]abc1"}], ")"}], 
    RowBox[{"-", "\[Alpha]abc2"}]], " ", 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "+", "\[Alpha]abc1"}], ")"}], "2"], "+", 
