 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"torrancesparrow", "/.", 
        RowBox[{"\[Alpha]ts", "\[Rule]", "#"}]}], "&"}], "/@", 
      RowBox[{"{", 
       RowBox[{"0.2027", ",", "0.3097", ",", "0.425", ",", "0.552"}], "}"}]}],
      ",", 
     RowBox[{
      RowBox[{
       RowBox[{"phong", "/.", 
        RowBox[{"\[Alpha]p", "\[Rule]", 
         RowBox[{"\[Alpha]b2\[Alpha]p", "[", "#", "]"}]}]}], "&"}], "/@", 
      RowBox[{"Range", "[", 
       RowBox[{"0.2", ",", "0.5", ",", "0.1"}], "]"}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Theta]", ",", "0", ",", 
     RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
