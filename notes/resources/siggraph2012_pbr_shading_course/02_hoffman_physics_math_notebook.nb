    RowBox[{
     RowBox[{"-", "2"}], "+", "\[Alpha]abc2"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "+", "\[Alpha]abc2"}], ")"}]}]]], "Output",
