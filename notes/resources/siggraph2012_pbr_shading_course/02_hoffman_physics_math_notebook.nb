       RowBox[{"{", 
        RowBox[{"0.1", ",", "0.5", ",", "1.0001", ",", "1.5"}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "0", ",", 
        RowBox[{"\[Pi]", "/", "2"}]}], "}"}], ",", 
      RowBox[{"PlotStyle", "\[Rule]", "abcCol"}]}], "]"}], ",", 
    RowBox[{"\"\<\!\(\*SubscriptBox[\(\[Alpha]\), \(abc1\)]\) = \>\"", "<>", 
     RowBox[{"ToString", "[", "x", "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"GraphicsGrid", "[", 
  RowBox[{
