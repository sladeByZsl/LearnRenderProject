Cell[TextData[{
 "For rough surfaces (left plot), the equivalence holds about as well as can \
be expected, but the shape of the NDFs starts to differ significantly as ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]]],
 " increases. For relatively smooth surfaces (right plot) ",
 "the two NDFs match surprisingly well. This is to Phong\[CloseCurlyQuote]s \
credit, who devised his NDF (although not as such) purely from observation. \
As the value of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Alpha]", "b"], TraditionalForm]]],
 " decreases, the match improves."
}], "Text",
 CellChangeTimes->{{3.556161140590465*^9, 3.556161197693555*^9}}],

